rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'manager' ||
        request.auth.token.role == 'project_manager' ||
        request.auth.token.role == 'sales_executive'
      );
    }

    function ownsResource(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Branding files (public access)
    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User avatars
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if ownsResource(userId) || isAdmin();
      allow delete: if ownsResource(userId) || isAdmin();
    }

    // Project files (optimized for video streaming)
    match /projects/{projectId}/{allPaths=**} {
      // HLS streaming files - public read for streaming
      match /hls/{allPaths=**} {
        allow read: if true;
        allow write: if isAuthenticated();
        allow delete: if isStaff();
      }

      // Thumbnails - public read
      match /thumbnails/{allPaths=**} {
        allow read: if true;
        allow write: if isAuthenticated();
        allow delete: if isStaff();
      }

      // Original videos - authenticated read
      match /videos/{allPaths=**} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
        allow delete: if isStaff();
      }

      // Other project files
      match /{allPaths=**} {
        allow read, write: if isAuthenticated();
        allow delete: if isStaff();
      }
    }

    // Raw footage (multipart uploads)
    match /raw_footage/{allPaths=**} {
      allow read, write: if isAuthenticated();
      allow delete: if isStaff();
    }

    // Public assets
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default rule - authenticated access
    match /{allPaths=**} {
      allow read, write: if isAuthenticated();
      allow delete: if isStaff();
    }
  }
}
